# ---- Site ----
# Public base URL (used for SEO: sitemap, robots, canonical, OG)
SITE_URL=http://localhost:3000

# ---- Storage ----
# Where content lives: "fs" (JSON files, default self-host), "sqlite"
# (data/edgepress.sqlite, Node 22.5+), or "kv" (Cloudflare KV + R2).
EDGEPRESS_STORAGE=fs
# DATA_DIR=./data   # fs/sqlite: where to store documents + media

# ---- Admin panel ----
ADMIN_PASSWORD=admin
# Super-admin (developer master key). Can reset the client admin password.
SUPERADMIN_PASSWORD=
ADMIN_SECRET=change-me-to-a-long-random-string

# ---- Lead notifications (all optional; each no-ops if unset) ----
# Email via Resend
RESEND_API_KEY=
LEAD_NOTIFY_TO=
LEAD_NOTIFY_FROM=leads@example.com
# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# SMS + WhatsApp via Twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_SMS_FROM=
SMS_NOTIFY_TO=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
WHATSAPP_NOTIFY_TO=whatsapp:+1XXXXXXXXXX
# CRM webhook (Zapier / Make / HubSpot / GoHighLevel inbound URL)
CRM_WEBHOOK_URL=

# ---- Anti-spam (optional) ----
RECAPTCHA_SECRET=
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=

# ---- Scheduled follow-ups (optional) ----
# GET /api/cron/followups?key=CRON_SECRET  (wire to an OS cron / uptime pinger)
CRON_SECRET=
FOLLOWUP_DAYS=2

# ---- Maps (optional — mock data until set) ----
GOOGLE_MAPS_API_KEY=

# ---- Auto-update AI extraction (optional) ----
ANTHROPIC_API_KEY=
REFRESH_MODEL=claude-haiku-4-5-20251001
