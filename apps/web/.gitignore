# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# cloudflare / opennext build output
/.open-next/
/.wrangler/
/.dev.vars

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files — the public repo ships only the .example templates.
# Your real .env.production (with YOUR site URL) stays local, never committed.
.env*
!.env.example
!.env.production.example

# Personal Cloudflare deploy config (your KV id + your domain). The public repo
# ships wrangler.jsonc.example; each adopter copies it to their own wrangler.jsonc.
/wrangler.jsonc

# runtime data store (leads, events, admin config — contains personal data)
/data
/backups

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
