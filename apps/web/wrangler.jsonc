{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "edgepress",
  "main": ".open-next/worker.js",
  "compatibility_date": "2025-09-23",
  "compatibility_flags": ["nodejs_compat"],
  "assets": {
    "binding": "ASSETS",
    "directory": ".open-next/assets"
  },
  // Default EdgePress storage: Cloudflare KV (documents) + R2 (media).
  // Swap these bindings — or set EDGEPRESS_STORAGE/EDGEPRESS_MEDIA to "fs" — to
  // run on any other host. The KV id below is created per-account at deploy.
  "kv_namespaces": [
    {
      "binding": "APP_KV",
      "id": "58a978634bd148ac94fd9ab4eb60a853"
    }
  ],
  "r2_buckets": [
    {
      "binding": "MEDIA",
      "bucket_name": "edgepress-media"
    }
  ],
  // Cloudflare Workers AI — the free, no-API-key default AI provider. Users can
  // also bring their own Anthropic/OpenAI/Google keys in the admin AI panel.
  "ai": {
    "binding": "AI"
  },
  "workers_dev": true,
  "vars": {
    "SITE_URL": "https://edgepress.mh-bamzadeh.workers.dev",
    "EDGEPRESS_STORAGE": "kv",
    "EDGEPRESS_MEDIA": "r2"
  },
  "observability": {
    "enabled": true
  }
}
